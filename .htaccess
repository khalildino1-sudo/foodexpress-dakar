# ============================================================
# FoodExpress Dakar - Apache Configuration
# ============================================================

# Activer le mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    
    # Définir le répertoire racine
    RewriteBase /
    
    # Rediriger les requêtes sans www vers www (optionnel)
    # RewriteCond %{HTTP_HOST} !^www\. [NC]
    # RewriteRule ^(.*)$ http://www.%{HTTP_HOST}/$1 [R=301,L]
    
    # Ne pas réécrire les requêtes pour les fichiers existants
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Réécrire vers index.php
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>

# ============================================================
# Protéger les dossiers sensibles
# ============================================================
<FilesMatch "(^#.*#|\.(conf|sql|fla|psd|ini|log|sh|inc|swp|dist|env)$)">
    Order allow,deny
    Deny from all
    Satisfy All
</FilesMatch>

# Protéger les répertoires sensibles
<DirectoryMatch "^/(config|database|vendor)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</DirectoryMatch>

# ============================================================
# Configuration PHP
# ============================================================
<IfModule mod_php.c>
    php_flag display_errors off
    php_value upload_max_filesize 20M
    php_value post_max_size 20M
    php_value memory_limit 128M
    php_value max_execution_time 300
</IfModule>

# ============================================================
# Gestion du cache (optionnel)
# ============================================================
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpg "access plus 1 year"
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
</IfModule>

# ============================================================
# En-têtes de sécurité
# ============================================================
<IfModule mod_headers.c>
    # Prévenir l'exploitation MIME-type
    Header set X-Content-Type-Options "nosniff"
    # Activer la protection XSS
    Header set X-XSS-Protection "1; mode=block"
    # Clickjacking protection
    Header set X-Frame-Options "SAMEORIGIN"
</IfModule>

